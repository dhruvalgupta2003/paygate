# =============================================================================
# Limen environment configuration
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in values. Never commit .env.
# Every variable is also documented in docs/deployment.md.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info              # trace | debug | info | warn | error | fatal
PORT=4021
HOST=0.0.0.0
LIMEN_UPSTREAM_URL=http://localhost:3000   # The API that Limen proxies

# ---- Receiving wallets (REQUIRED) -------------------------------------------
# Address that will receive USDC payments on each chain.
LIMEN_WALLET_BASE=0x0000000000000000000000000000000000000000
LIMEN_WALLET_SOLANA=11111111111111111111111111111111

# ---- Chain settings ---------------------------------------------------------
# Supported: base, base-sepolia, solana, solana-devnet
LIMEN_DEFAULT_CHAIN=base
LIMEN_BASE_RPC_URL=https://mainnet.base.org
LIMEN_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
LIMEN_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
LIMEN_SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

# Canonical USDC contract addresses. Leave defaults unless running on a fork.
LIMEN_USDC_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
LIMEN_USDC_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
LIMEN_USDC_SOLANA=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
LIMEN_USDC_SOLANA_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ---- x402 facilitator (optional, recommended) -------------------------------
# Coinbase-hosted facilitator URL. If set, Limen uses the facilitator's
# /verify and /settle endpoints instead of self-settled on-chain verification.
LIMEN_FACILITATOR_URL=https://x402.org/facilitator
LIMEN_FACILITATOR_API_KEY=

# ---- Settlement tuning ------------------------------------------------------
LIMEN_PAYMENT_TTL_SECONDS=300         # Max age of a signed payment auth
LIMEN_CONFIRMATIONS_BASE=2            # Blocks to wait before acceptance
LIMEN_CONFIRMATIONS_SOLANA=confirmed  # confirmed | finalized

# ---- Persistence ------------------------------------------------------------
LIMEN_DATABASE_URL=postgresql://limen:limen@localhost:5432/limen
LIMEN_REDIS_URL=redis://localhost:6379/0

# ---- Dashboard + API --------------------------------------------------------
LIMEN_DASHBOARD_URL=http://localhost:5173
LIMEN_API_URL=http://localhost:4020
LIMEN_ADMIN_SECRET=replace-me-with-openssl-rand-base64-48
LIMEN_JWT_SECRET=replace-me-with-openssl-rand-base64-48
LIMEN_WEBHOOK_SIGNING_SECRET=replace-me-with-openssl-rand-base64-48

# ---- Analytics + monitoring -------------------------------------------------
LIMEN_METRICS_ENABLED=true
LIMEN_METRICS_PORT=9464               # Prometheus scrape endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=limen
SENTRY_DSN=

# ---- Alerting ---------------------------------------------------------------
LIMEN_ALERTS_TELEGRAM_TOKEN=
LIMEN_ALERTS_TELEGRAM_CHAT_ID=
LIMEN_ALERTS_DISCORD_WEBHOOK=
LIMEN_ALERTS_RESEND_API_KEY=

# ---- Compliance -------------------------------------------------------------
# Circle sanctions API for USDC compliance screening.
LIMEN_COMPLIANCE_ENABLED=true
LIMEN_CIRCLE_API_KEY=
LIMEN_COMPLIANCE_BLOCKLIST_PATH=./config/blocklist.json

# ---- Feature flags ----------------------------------------------------------
LIMEN_ALLOW_ANONYMOUS_DISCOVERY=true
LIMEN_DIRECTORY_ENABLED=true
LIMEN_DEV_MODE=false                  # Bypass on-chain verify on localhost
