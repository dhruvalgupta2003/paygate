# =============================================================================
# PayGate environment configuration
# -----------------------------------------------------------------------------
# Copy this file to .env and fill in values. Never commit .env.
# Every variable is also documented in docs/deployment.md.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info              # trace | debug | info | warn | error | fatal
PORT=4021
HOST=0.0.0.0
PAYGATE_UPSTREAM_URL=http://localhost:3000   # The API that PayGate proxies

# ---- Receiving wallets (REQUIRED) -------------------------------------------
# Address that will receive USDC payments on each chain.
PAYGATE_WALLET_BASE=0x0000000000000000000000000000000000000000
PAYGATE_WALLET_SOLANA=11111111111111111111111111111111

# ---- Chain settings ---------------------------------------------------------
# Supported: base, base-sepolia, solana, solana-devnet
PAYGATE_DEFAULT_CHAIN=base
PAYGATE_BASE_RPC_URL=https://mainnet.base.org
PAYGATE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
PAYGATE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
PAYGATE_SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com

# Canonical USDC contract addresses. Leave defaults unless running on a fork.
PAYGATE_USDC_BASE=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
PAYGATE_USDC_BASE_SEPOLIA=0x036CbD53842c5426634e7929541eC2318f3dCF7e
PAYGATE_USDC_SOLANA=EPjFWdd5AufqSSqeM2qN1xzybapC8G4wEGGkZwyTDt1v
PAYGATE_USDC_SOLANA_DEVNET=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU

# ---- x402 facilitator (optional, recommended) -------------------------------
# Coinbase-hosted facilitator URL. If set, PayGate uses the facilitator's
# /verify and /settle endpoints instead of self-settled on-chain verification.
PAYGATE_FACILITATOR_URL=https://x402.org/facilitator
PAYGATE_FACILITATOR_API_KEY=

# ---- Settlement tuning ------------------------------------------------------
PAYGATE_PAYMENT_TTL_SECONDS=300         # Max age of a signed payment auth
PAYGATE_CONFIRMATIONS_BASE=2            # Blocks to wait before acceptance
PAYGATE_CONFIRMATIONS_SOLANA=confirmed  # confirmed | finalized

# ---- Persistence ------------------------------------------------------------
PAYGATE_DATABASE_URL=postgresql://paygate:paygate@localhost:5432/paygate
PAYGATE_REDIS_URL=redis://localhost:6379/0

# ---- Dashboard + API --------------------------------------------------------
PAYGATE_DASHBOARD_URL=http://localhost:5173
PAYGATE_API_URL=http://localhost:4020
PAYGATE_ADMIN_SECRET=replace-me-with-openssl-rand-base64-48
PAYGATE_JWT_SECRET=replace-me-with-openssl-rand-base64-48
PAYGATE_WEBHOOK_SIGNING_SECRET=replace-me-with-openssl-rand-base64-48

# ---- Analytics + monitoring -------------------------------------------------
PAYGATE_METRICS_ENABLED=true
PAYGATE_METRICS_PORT=9464               # Prometheus scrape endpoint
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=paygate
SENTRY_DSN=

# ---- Alerting ---------------------------------------------------------------
PAYGATE_ALERTS_TELEGRAM_TOKEN=
PAYGATE_ALERTS_TELEGRAM_CHAT_ID=
PAYGATE_ALERTS_DISCORD_WEBHOOK=
PAYGATE_ALERTS_RESEND_API_KEY=

# ---- Compliance -------------------------------------------------------------
# Circle sanctions API for USDC compliance screening.
PAYGATE_COMPLIANCE_ENABLED=true
PAYGATE_CIRCLE_API_KEY=
PAYGATE_COMPLIANCE_BLOCKLIST_PATH=./config/blocklist.json

# ---- Feature flags ----------------------------------------------------------
PAYGATE_ALLOW_ANONYMOUS_DISCOVERY=true
PAYGATE_DIRECTORY_ENABLED=true
PAYGATE_DEV_MODE=false                  # Bypass on-chain verify on localhost
