# Limen code ownership.
#
# Lines use `<pattern> <owner1> <owner2> ...`. The last matching pattern wins.
# See AGENTS.md § 1 rule 3 and SECURITY.md — verification paths require a
# second reviewer from @limen/security.

# ------------------------------------------------------------------
# Default owners — core team reviews everything
# ------------------------------------------------------------------
*                                                 @limen/core

# ------------------------------------------------------------------
# Verification + chain-specific logic — security review required
# ------------------------------------------------------------------
/packages/limen-node/src/chains/                @limen/security @limen/core
/packages/limen-node/src/verification/          @limen/security @limen/core
/packages/limen-python/limen/chains/          @limen/security @limen/core
/packages/limen-python/limen/verification/    @limen/security @limen/core

# ------------------------------------------------------------------
# Smart contracts
# ------------------------------------------------------------------
/contracts/                                       @limen/security @limen/contracts
/contracts/base/                                  @limen/security @limen/contracts
/contracts/solana/                                @limen/security @limen/contracts

# ------------------------------------------------------------------
# Security-sensitive docs
# ------------------------------------------------------------------
/SECURITY.md                                      @limen/security
/AGENTS.md                                        @limen/core @limen/security
/docs/security.md                                 @limen/security
/docs/compliance.md                               @limen/security

# ------------------------------------------------------------------
# Release + supply-chain workflows
# ------------------------------------------------------------------
/.github/workflows/publish-npm.yml                @limen/core @limen/security
/.github/workflows/publish-pypi.yml               @limen/core @limen/security
/.github/workflows/publish-docker.yml             @limen/core @limen/security
/.github/workflows/security-scan.yml              @limen/security
/.github/workflows/codeql.yml                     @limen/security
/.github/workflows/sbom.yml                       @limen/security @limen/core
/.github/dependabot.yml                           @limen/security @limen/core
/.github/renovate.json                            @limen/security @limen/core

# ------------------------------------------------------------------
# Apps
# ------------------------------------------------------------------
/apps/api/                                        @limen/backend
/apps/dashboard/                                  @limen/frontend

# ------------------------------------------------------------------
# SDKs (non-verification paths)
# ------------------------------------------------------------------
/packages/limen-node/                           @limen/core @limen/node
/packages/limen-python/                         @limen/core @limen/python

# ------------------------------------------------------------------
# Docs site
# ------------------------------------------------------------------
/docs/                                            @limen/docs @limen/core
