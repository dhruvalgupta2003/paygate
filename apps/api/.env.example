# =============================================================================
# PayGate API — environment configuration
# -----------------------------------------------------------------------------
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info                          # trace | debug | info | warn | error | fatal
PORT=4020
HOST=0.0.0.0

# ---- Persistence ------------------------------------------------------------
PAYGATE_DATABASE_URL=postgresql://paygate:paygate@localhost:5432/paygate
PAYGATE_REDIS_URL=redis://localhost:6379/1

# ---- Auth + cross-origin ----------------------------------------------------
# JWT signing secret for dashboard sessions (HS256). Must be >= 32 bytes.
PAYGATE_JWT_SECRET=replace-me-with-openssl-rand-base64-48
# Dashboard origin(s) allowed by CORS — comma-separated list, no wildcards.
PAYGATE_DASHBOARD_URL=http://localhost:5173
# Comma-separated list of ed25519 public keys (base64, 32 bytes) allowed to
# sign admin requests via X-PayGate-Admin.
PAYGATE_ADMIN_PUBKEY_ALLOWLIST=

# ---- Webhook signing --------------------------------------------------------
# Default HMAC-SHA256 secret used when signing outbound webhooks.
PAYGATE_WEBHOOK_SIGNING_SECRET=replace-me-with-openssl-rand-base64-48
PAYGATE_WEBHOOK_TIMEOUT_MS=5000

# ---- Observability ----------------------------------------------------------
PAYGATE_API_METRICS_PORT=9464
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=paygate-api
SENTRY_DSN=

# ---- Rate limits (admin API itself) -----------------------------------------
PAYGATE_API_RATE_LIMIT_PER_SECOND=60
PAYGATE_API_RATE_LIMIT_PER_MINUTE=1000

# ---- Evidence + audit -------------------------------------------------------
PAYGATE_AUDIT_DIR=./data/audit
# If set, audit-shipper worker uploads sealed NDJSON nightly.
PAYGATE_AUDIT_S3_BUCKET=
PAYGATE_AUDIT_S3_REGION=us-east-1

# ---- Feature flags ----------------------------------------------------------
PAYGATE_API_ENABLE_DIRECTORY=true
PAYGATE_API_ENABLE_DSR=true
