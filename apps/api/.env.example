# =============================================================================
# Limen API — environment configuration
# -----------------------------------------------------------------------------
# Copy to .env and fill in values. Never commit .env.
# =============================================================================

# ---- Runtime ----------------------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info                          # trace | debug | info | warn | error | fatal
PORT=4020
HOST=0.0.0.0

# ---- Persistence ------------------------------------------------------------
LIMEN_DATABASE_URL=postgresql://limen:limen@localhost:5432/limen
LIMEN_REDIS_URL=redis://localhost:6379/1

# ---- Auth + cross-origin ----------------------------------------------------
# JWT signing secret for dashboard sessions (HS256). Must be >= 32 bytes.
LIMEN_JWT_SECRET=replace-me-with-openssl-rand-base64-48
# Dashboard origin(s) allowed by CORS — comma-separated list, no wildcards.
LIMEN_DASHBOARD_URL=http://localhost:5173
# Comma-separated list of ed25519 public keys (base64, 32 bytes) allowed to
# sign admin requests via X-Limen-Admin.
LIMEN_ADMIN_PUBKEY_ALLOWLIST=

# ---- Webhook signing --------------------------------------------------------
# Default HMAC-SHA256 secret used when signing outbound webhooks.
LIMEN_WEBHOOK_SIGNING_SECRET=replace-me-with-openssl-rand-base64-48
LIMEN_WEBHOOK_TIMEOUT_MS=5000

# ---- Observability ----------------------------------------------------------
LIMEN_API_METRICS_PORT=9464
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=limen-api
SENTRY_DSN=

# ---- Rate limits (admin API itself) -----------------------------------------
LIMEN_API_RATE_LIMIT_PER_SECOND=60
LIMEN_API_RATE_LIMIT_PER_MINUTE=1000

# ---- Evidence + audit -------------------------------------------------------
LIMEN_AUDIT_DIR=./data/audit
# If set, audit-shipper worker uploads sealed NDJSON nightly.
LIMEN_AUDIT_S3_BUCKET=
LIMEN_AUDIT_S3_REGION=us-east-1

# ---- Feature flags ----------------------------------------------------------
LIMEN_API_ENABLE_DIRECTORY=true
LIMEN_API_ENABLE_DSR=true
