{
  "name": "@limen/api",
  "version": "0.1.0",
  "private": true,
  "description": "Limen backend API: dashboard, public directory, analytics, webhooks, refunds, DSR, SOC 2 evidence.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist/**/*",
    "migrations/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --onSuccess 'node dist/index.js'",
    "start": "node dist/index.js",
    "worker:webhooks": "node dist/workers/webhook-worker.js",
    "worker:audit-shipper": "node dist/workers/audit-shipper.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "clean": "rimraf dist .turbo *.tsbuildinfo",
    "db:migrate": "node dist/scripts/migrate.js",
    "db:generate": "drizzle-kit generate",
    "openapi:generate": "node dist/scripts/openapi.js"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-openapi": "^0.18.0",
    "@hono/zod-validator": "^0.4.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/sdk-node": "^0.54.0",
    "archiver": "^7.0.1",
    "drizzle-orm": "^0.36.0",
    "hono": "^4.6.8",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "postgres": "^3.4.5",
    "prom-client": "^15.1.3",
    "stripe": "^22.0.2",
    "ulid": "^2.3.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^6.0.3",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.4",
    "drizzle-kit": "^0.28.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
