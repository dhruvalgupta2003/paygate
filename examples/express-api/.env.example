# Copy to .env and fill in. Use a TESTNET address — receive-only.
# Never commit a populated .env.

# Receiving wallet for Base Sepolia USDC (0x...).
PAYGATE_WALLET_BASE_SEPOLIA=0x0000000000000000000000000000000000000000

# Optional custom RPC. Defaults to https://sepolia.base.org.
PAYGATE_BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Redis for nonce store + rate limits.
REDIS_URL=redis://127.0.0.1:6379

# Express port.
PORT=3000
