{
  "name": "paygate",
  "version": "0.1.0",
  "private": true,
  "description": "x402 paywall for AI agent traffic — Node.js + Python SDKs, proxy, dashboard, and API directory.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/paygate/paygate.git"
  },
  "homepage": "https://paygate.dev",
  "bugs": {
    "url": "https://github.com/paygate/paygate/issues"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rimraf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yaml,yml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,yaml,yml}\" --ignore-path .gitignore",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build --filter=@paygate/* && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.9",
    "@types/node": "^22.9.0",
    "prettier": "^3.3.3",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3"
  }
}
