{
  "name": "@limen/mcp-operator",
  "version": "0.1.0",
  "description": "MCP server exposing the Limen admin API (transactions, endpoints, API keys, billing, analytics) as tools for LLM clients like Claude Desktop and Claude Code.",
  "license": "MIT",
  "author": "Limen contributors",
  "homepage": "https://limen.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhruvalgupta2003/limen.git",
    "directory": "packages/limen-mcp-operator"
  },
  "keywords": ["mcp", "model-context-protocol", "claude", "x402", "limen", "anthropic", "oauth"],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "limen-mcp-operator": "./dist/server.js",
    "limen-mcp-operator-http": "./dist/http.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist/**/*", "README.md", "LICENSE"],
  "engines": { "node": ">=20.10.0" },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/server.js",
    "start:http": "node dist/http.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "express": "^4.21.1",
    "jose": "^6.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
