{
  "name": "@limen/node",
  "version": "0.1.0",
  "description": "x402 paywall for AI agent traffic. Drop-in middleware + standalone proxy for Express, Fastify, Hono, and Next.js. USDC on Base and Solana.",
  "license": "MIT",
  "homepage": "https://limen.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/dhruvalgupta2003/limen.git",
    "directory": "packages/limen-node"
  },
  "bugs": {
    "url": "https://github.com/dhruvalgupta2003/limen/issues"
  },
  "keywords": [
    "x402",
    "paywall",
    "micropayments",
    "stablecoin",
    "usdc",
    "base",
    "solana",
    "ai-agents",
    "agentic-payments",
    "http-402"
  ],
  "author": "Limen contributors",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "limen": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./express": {
      "types": "./dist/middleware/express.d.ts",
      "import": "./dist/middleware/express.js",
      "require": "./dist/middleware/express.cjs"
    },
    "./fastify": {
      "types": "./dist/middleware/fastify.d.ts",
      "import": "./dist/middleware/fastify.js",
      "require": "./dist/middleware/fastify.cjs"
    },
    "./hono": {
      "types": "./dist/middleware/hono.d.ts",
      "import": "./dist/middleware/hono.js",
      "require": "./dist/middleware/hono.cjs"
    },
    "./next": {
      "types": "./dist/middleware/next.d.ts",
      "import": "./dist/middleware/next.js",
      "require": "./dist/middleware/next.cjs"
    }
  },
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@solana/spl-token": "^0.4.9",
    "@solana/web3.js": "^1.95.4",
    "bs58": "^6.0.0",
    "commander": "^12.1.0",
    "hono": "^4.6.8",
    "ioredis": "^5.4.1",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "tweetnacl": "^1.0.3",
    "ulid": "^2.3.0",
    "undici": "^6.21.0",
    "viem": "^2.21.45",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.13.0",
    "@typescript-eslint/parser": "^8.13.0",
    "@vitest/coverage-v8": "^2.1.4",
    "eslint": "^9.14.0",
    "express": "^4.21.1",
    "fastify": "^5.1.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "peerDependencies": {
    "express": ">=4",
    "fastify": ">=4",
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "express": { "optional": true },
    "fastify": { "optional": true },
    "next": { "optional": true }
  }
}
